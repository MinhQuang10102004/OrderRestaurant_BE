generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          BigInt  @id @default(autoincrement())
  name        String  @db.VarChar(50)
  description String? @db.VarChar(255)
  users       User[]

  @@map("roles")
}

model User {
  id             BigInt         @id @default(autoincrement())
  full_name      String         @db.VarChar(100)
  email          String         @unique @db.VarChar(100)
  password       String         @db.VarChar(255)
  phone          String?        @unique @db.VarChar(20)
  role_id        BigInt
  points         Int            @default(0)
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  deleted_at     DateTime?
  loyalty_points LoyaltyPoint[]
  orders         Order[]
  role           Role           @relation(fields: [role_id], references: [id])

  @@map("users")
}

model Category {
  id          BigInt    @id @default(autoincrement())
  name        String    @db.VarChar(100)
  description String?   @db.VarChar(255)
  image_url   String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?
  dishes      Dish[]

  @@map("categories")
}

model Dish {
  id           BigInt      @id @default(autoincrement())
  name         String      @db.VarChar(150)
  description  String?
  price        Decimal     @db.Decimal(19, 2)
  image_url    String?
  category_id  BigInt
  is_available Boolean     @default(true)
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt
  deleted_at   DateTime?
  category     Category    @relation(fields: [category_id], references: [id])
  order_items  OrderItem[]

  @@map("dishes")
}

model Area {
  id         BigInt    @id @default(autoincrement())
  name       String    @db.VarChar(100)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?
  tables     Table[]

  @@map("areas")
}

model Table {
  id           BigInt    @id @default(autoincrement())
  table_number String    @db.VarChar(20)
  capacity     Int
  status       String    @db.VarChar(50)
  area_id      BigInt
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?
  orders       Order[]
  area         Area      @relation(fields: [area_id], references: [id])

  @@map("tables")
}

model Order {
  id              BigInt      @id @default(autoincrement())
  customer_id     BigInt?
  staff_id        BigInt?
  table_id        BigInt?
  total_amount    Decimal     @db.Decimal(19, 2)
  discount_amount Decimal     @default(0) @db.Decimal(19, 2)
  final_amount    Decimal     @db.Decimal(19, 2)
  status          String      @db.VarChar(50)
  notes           String?
  voucher_id      BigInt?
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt
  deleted_at      DateTime?
  order_items     OrderItem[]
  customer        User?       @relation(fields: [customer_id], references: [id])
  table           Table?      @relation(fields: [table_id], references: [id])
  voucher         Voucher?    @relation(fields: [voucher_id], references: [id])
  payment         Payment?

  @@map("orders")
}

model OrderItem {
  id             BigInt  @id @default(autoincrement())
  order_id       BigInt
  dish_id        BigInt
  quantity       Int
  price_at_order Decimal @db.Decimal(19, 2)
  status         String  @db.VarChar(50)
  notes          String?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @default(now()) @updatedAt // Thêm @default(now()) ở đây
  dish           Dish    @relation(fields: [dish_id], references: [id])
  order          Order   @relation(fields: [order_id], references: [id])

  @@map("order_items")
}

model Payment {
  id             BigInt   @id @default(autoincrement())
  order_id       BigInt   @unique
  amount         Decimal  @db.Decimal(19, 2)
  method         String   @db.VarChar(50)
  status         String   @db.VarChar(50)
  transaction_id String?  @db.VarChar(255)
  payment_date   DateTime @default(now())
  order          Order    @relation(fields: [order_id], references: [id])

  @@map("payments")
}

model Voucher {
  id              BigInt    @id @default(autoincrement())
  code            String    @unique @db.VarChar(50)
  discount_type   String    @db.VarChar(20)
  value           Decimal   @db.Decimal(19, 2)
  min_order_value Decimal   @db.Decimal(19, 2)
  start_date      DateTime
  end_date        DateTime
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?
  orders          Order[]

  @@map("vouchers")
}

model LoyaltyPoint {
  id             BigInt   @id @default(autoincrement())
  user_id        BigInt
  points_changed Int
  reason         String   @db.VarChar(255)
  created_at     DateTime @default(now())
  user           User     @relation(fields: [user_id], references: [id])

  @@map("loyalty_points")
}
